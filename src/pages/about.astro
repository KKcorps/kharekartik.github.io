	<script is:inline>
		(() => {
			const root = document.documentElement;
			const themeValue = document.querySelector('[data-about-theme]');
			const gridCanvas = document.getElementById('about-grid-canvas');
			const dungeonDisplay = document.getElementById('about-dungeon-display');
			const dungeonStatus = document.getElementById('about-dungeon-status');
			const resetButton = document.getElementById('about-reset-button');

			if (themeValue instanceof HTMLElement) {
				themeValue.textContent = (root.dataset.theme === 'light' ? 'light' : 'dark').toUpperCase();
			}

			if (gridCanvas instanceof HTMLCanvasElement) {
				const context = gridCanvas.getContext('2d');
				if (context) {
					const width = gridCanvas.width;
					const height = gridCanvas.height;
					const cell = 12;
					const columns = Math.floor(width / cell);
					const rows = Math.floor(height / cell);
					const createKGlyph = (originColumn, originRow) => [
						...Array.from({ length: 8 }, (_, offset) => ({
							column: originColumn,
							row: originRow + offset,
						})),
						{ column: originColumn + 1, row: originRow + 4 },
						{ column: originColumn + 2, row: originRow + 3 },
						{ column: originColumn + 3, row: originRow + 2 },
						{ column: originColumn + 1, row: originRow + 5 },
						{ column: originColumn + 2, row: originRow + 6 },
						{ column: originColumn + 3, row: originRow + 7 },
					];
						const firstK = createKGlyph(2, 3);
						const secondK = createKGlyph(8, 3);
						const kkPoints = [...firstK, ...secondK];
						const ambientPoints = [
							{ column: 1, row: 1 },
							{ column: 12, row: 2 },
						{ column: 11, row: 5 },
						{ column: 2, row: 11 },
						{ column: 10, row: 10 },
						{ column: 12, row: 12 },
					];
					let frame = 0;
					let lastFrameTime = 0;

					const getColor = (name, fallback) =>
						getComputedStyle(root).getPropertyValue(name).trim() || fallback;
					const drawCell = (column, row, fill, size = 4, offset = 4) => {
						context.fillStyle = fill;
						context.fillRect(column * cell + offset, row * cell + offset, size, size);
					};

					const drawGridWidget = (timestamp = 0) => {
						if (lastFrameTime === 0) {
							lastFrameTime = timestamp;
						}

						const delta = (timestamp - lastFrameTime) / (1000 / 60);
						lastFrameTime = timestamp;
						frame += delta * 0.45;

						const accent = getColor('--accent', '#c5ff47');
						const accentDim = getColor('--accent-dim', 'rgba(197,255,71,0.12)');
						const widgetBackground = getColor('--about-widget-bg', '#0b0b0b');
						const gridLine = getColor('--about-grid-line', '#1a1a1a');
						const ghostColor = getColor('--about-widget-ghost', '#333333');

						context.clearRect(0, 0, width, height);
						context.fillStyle = widgetBackground;
						context.fillRect(0, 0, width, height);
						context.strokeStyle = gridLine;
						context.lineWidth = 0.5;

						for (let row = 0; row <= rows; row += 1) {
							context.beginPath();
							context.moveTo(0, row * cell);
							context.lineTo(width, row * cell);
							context.stroke();
						}

						for (let column = 0; column <= columns; column += 1) {
							context.beginPath();
							context.moveTo(column * cell, 0);
							context.lineTo(column * cell, height);
							context.stroke();
						}

						ambientPoints.forEach((point, index) => {
							const twinkle = (Math.sin(frame * 0.05 + index * 1.3) + 1) / 2;
							drawCell(point.column, point.row, twinkle > 0.55 ? accentDim : ghostColor, 2, 5);
						});

						kkPoints.forEach((point, index) => {
							const pulse = (Math.sin(frame * 0.08 + point.row * 0.7 + index * 0.15) + 1) / 2;
							drawCell(point.column, point.row, ghostColor, 4, 4);
							if (pulse > 0.3) {
								drawCell(point.column, point.row, accent, pulse > 0.75 ? 6 : 5, pulse > 0.75 ? 3 : 3.5);
							}
						});

						requestAnimationFrame(drawGridWidget);
					};

					drawGridWidget();
				}
			}

			if (
				!(dungeonDisplay instanceof HTMLElement) ||
				!(dungeonStatus instanceof HTMLElement) ||
				!(resetButton instanceof HTMLButtonElement)
			) {
				return;
			}

			const rows = 14;
			const columns = 36;
			let grid = [];
			let player = { row: 1, column: 1 };
			let goal = { row: rows - 2, column: columns - 2 };
			let moves = 0;

			const setDungeonStatus = (message) => {
				dungeonStatus.innerHTML = message;
			};

			const makeGrid = () =>
				Array.from({ length: rows }, (_, rowIndex) =>
					Array.from({ length: columns }, (_, columnIndex) => {
						if (
							rowIndex === 0 ||
							rowIndex === rows - 1 ||
							columnIndex === 0 ||
							columnIndex === columns - 1
						) {
							return '#';
						}

						return Math.random() < 0.28 ? '#' : '.';
					}),
				);

			const renderDungeon = () => {
				let output = '';
				for (let rowIndex = 0; rowIndex < rows; rowIndex += 1) {
					for (let columnIndex = 0; columnIndex < columns; columnIndex += 1) {
						if (rowIndex === player.row && columnIndex === player.column) {
							output += '<span class="is-packet">@</span>';
						} else if (rowIndex === goal.row && columnIndex === goal.column) {
							output += '<span class="is-goal-tile">$</span>';
						} else {
							output += grid[rowIndex][columnIndex];
						}
					}
					output += '\n';
				}

				dungeonDisplay.innerHTML = output;
			};

			const resetDungeon = () => {
				grid = makeGrid();
				player = { row: 1, column: 1 };
				goal = { row: rows - 2, column: columns - 2 };
				moves = 0;
				grid[player.row][player.column] = '.';
				grid[goal.row][goal.column] = '.';

				let rowIndex = 1;
				let columnIndex = 1;
				while (rowIndex < rows - 2 || columnIndex < columns - 2) {
					if (rowIndex < rows - 2 && (columnIndex >= columns - 2 || Math.random() < 0.5)) {
						rowIndex += 1;
					} else {
						columnIndex += 1;
					}

					grid[rowIndex][columnIndex] = '.';
				}

				setDungeonStatus('route the packet<br>through the chaos.');
				renderDungeon();
			};

			const movePlayer = (deltaRow, deltaColumn) => {
				const nextRow = player.row + deltaRow;
				const nextColumn = player.column + deltaColumn;

				if (
					nextRow < 0 ||
					nextRow >= rows ||
					nextColumn < 0 ||
					nextColumn >= columns ||
					grid[nextRow][nextColumn] === '#'
				) {
					setDungeonStatus('packet hit a wall.<br>reroute.');
					return;
				}

				player.row = nextRow;
				player.column = nextColumn;
				moves += 1;

				if (player.row === goal.row && player.column === goal.column) {
					renderDungeon();
					setDungeonStatus(`packet delivered<br>in ${moves} hops.`);
					return;
				}

				renderDungeon();
				setDungeonStatus('route stable.<br>keep pushing.');
			};

			document.addEventListener('keydown', (event) => {
				const key = event.key.toLowerCase();
				if (
					['arrowup', 'arrowdown', 'arrowleft', 'arrowright', 'w', 'a', 's', 'd', 'r'].includes(
						key,
					)
				) {
					event.preventDefault();
				}

				switch (key) {
					case 'arrowup':
					case 'w':
						movePlayer(-1, 0);
						break;
					case 'arrowdown':
					case 's':
						movePlayer(1, 0);
						break;
					case 'arrowleft':
					case 'a':
						movePlayer(0, -1);
						break;
					case 'arrowright':
					case 'd':
						movePlayer(0, 1);
						break;
					case 'r':
						resetDungeon();
						break;
				}
			});

			[
				['about-btn-up', () => movePlayer(-1, 0)],
				['about-btn-down', () => movePlayer(1, 0)],
				['about-btn-left', () => movePlayer(0, -1)],
				['about-btn-right', () => movePlayer(0, 1)],
			].forEach(([id, action]) => {
				const button = document.getElementById(id);
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}

				button.addEventListener('click', action);
				['pointerdown', 'pointerup', 'pointerleave', 'pointercancel'].forEach((eventName) => {
					button.addEventListener(eventName, () => {
						button.classList.toggle('is-pressed', eventName === 'pointerdown');
					});
				});
			});

			resetButton.addEventListener('click', resetDungeon);
			resetDungeon();
		})();
	</script>

