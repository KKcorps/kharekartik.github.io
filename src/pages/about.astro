---

<SiteLayout
	title="About"
	description="About Kartik, plus a tiny playable ASCII game."
	hideChrome
	bodyClass="about-terminal"
>
	<script is:inline data-accent-palettes={JSON.stringify(accentPalettes)}>
		(() => {
			const accentCycleKey = 'home-accent-cycle-index';
			const accentPaletteKey = 'home-accent-palette';
			const root = document.documentElement;
			const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
			const currentScript = document.currentScript;
			const accentPalettes = JSON.parse(currentScript?.dataset.accentPalettes ?? '[]');
			const parseHexToRgb = (hex) => {
				const normalized = hex.replace('#', '').trim();
				if (!/^[0-9a-fA-F]{6}$/.test(normalized)) {
					return null;
				}

				const red = Number.parseInt(normalized.slice(0, 2), 16);
				const green = Number.parseInt(normalized.slice(2, 4), 16);
				const blue = Number.parseInt(normalized.slice(4, 6), 16);

				return `${red} ${green} ${blue}`;
			};

			if (!Array.isArray(accentPalettes) || accentPalettes.length === 0) {
				return;
			}

			const storedCycleIndex = Number.parseInt(localStorage.getItem(accentCycleKey) ?? '-1', 10);
			const cycleIndex = Number.isFinite(storedCycleIndex)
				? (storedCycleIndex + 1) % accentPalettes.length
				: 0;
			const palette = accentPalettes[cycleIndex];
			const accent = palette[theme];
			const accentRgb = parseHexToRgb(accent.hex);

			localStorage.setItem(accentCycleKey, String(cycleIndex));
			localStorage.setItem(accentPaletteKey, JSON.stringify(palette));

			root.style.setProperty('--accent', accent.hex);
			root.style.setProperty('--accent-dim', accent.dim);
			root.style.setProperty('--about-accent-glow', accent.glow);

			if (accentRgb) {
				root.style.setProperty('--accent-rgb', accentRgb);
			}
		})();
	</script>

