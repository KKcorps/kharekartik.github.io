				[3, 7],
				[2, 6],
				[1, 5],
			];
			const arcadeArt = [
				createArt(
					'pac-man',
					'pac-man chase lane',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const pacCol = step;
						const ghostCol = wrap(step + 5);

						drawText(grid, 2, 1, '########');
						drawText(grid, 6, 1, '########');
						fillRow(grid, 4, '.');

						setCell(grid, 4, pacCol, step % 2 === 0 ? 'C' : 'O');
						setCell(grid, 4, ghostCol, 'G');

						return serializeGrid(grid);
					}),
				),
				createArt(
					'space-invaders',
					'space invaders firing line',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const offset = invaderStride[step];

						[0, 3, 6].forEach((colStart) => {
							setWrappedCell(grid, 1, offset + colStart, 'W');
							setWrappedCell(grid, 2, offset + colStart, 'M');
						});

						drawText(grid, 6, 1, '### ###');
						drawText(grid, 9, 3, '/A\\');

						if (step === 5) {
							setWrappedCell(grid, 2, offset + 3, '*');
						} else {
							const bulletRow = 8 - step;
							if (bulletRow >= 3) {
								setCell(grid, bulletRow, 4, '|');
							}
						}

						return serializeGrid(grid);
					}),
				),
				createArt(
					'pong',
					'pong rally in a tight loop',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const [ballRow, ballCol] = pongPath[step];
						const leftTop = Math.max(0, Math.min(7, ballCol <= 2 ? ballRow - 1 : 3));
						const rightTop = Math.max(0, Math.min(7, ballCol >= 7 ? ballRow - 1 : 3));

						drawColumn(grid, 0, leftTop, leftTop + 2, '|');
						drawColumn(grid, 9, rightTop, rightTop + 2, '|');
						setCell(grid, ballRow, ballCol, 'O');

						return serializeGrid(grid);
					}),
				),
				createArt(
					'tetris',
					'tetris drop, lock, and clear',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();

						drawColumn(grid, 0, 0, 8, '|');
						drawColumn(grid, 9, 0, 8, '|');
						drawText(grid, 9, 0, '##########');

						if (step <= 6) {
							drawText(grid, 8, 1, '##    ##');
							drawText(grid, step, 3, '====');
						} else if (step === 7) {
							drawText(grid, 8, 1, '########');
						} else if (step === 8) {
							drawText(grid, 8, 1, '********');
						}

						return serializeGrid(grid);
					}),
				),
				createArt(
					'snake',
					'snake circles the apple',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();

						setCell(grid, 4, 4, '@');

						for (let bodyStep = 3; bodyStep >= 1; bodyStep -= 1) {
							const [bodyRow, bodyCol] = snakeLoop[wrap(step - bodyStep)];
							setCell(grid, bodyRow, bodyCol, 'o');
						}

						const [headRow, headCol] = snakeLoop[step];
						setCell(grid, headRow, headCol, 'O');

						return serializeGrid(grid);
					}),
				),
				createArt(
					'breakout',
					'breakout brick hit and return',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const [ballRow, ballCol] = breakoutPath[step];
						const paddleCol = Math.max(1, Math.min(5, ballCol - 1));

						drawText(grid, 1, 1, step >= 4 ? '### ### ' : '########');
						drawText(grid, 9, paddleCol, '====');

						if (step === 4) {
							setCell(grid, 1, 7, '*');
						} else {
							setCell(grid, ballRow, ballCol, 'O');
						}

						return serializeGrid(grid);
					}),
				),
				createArt(
					'tron',
					'tron light cycles duel',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const [blueRow, blueCol] = tronBluePath[step];
						const [orangeRow, orangeCol] = tronOrangePath[step];

						drawText(grid, 0, 0, '##########');
						drawText(grid, 9, 0, '##########');

						for (let trailStep = 0; trailStep < step; trailStep += 1) {
							const [trailBlueRow, trailBlueCol] = tronBluePath[trailStep];
							const [trailOrangeRow, trailOrangeCol] = tronOrangePath[trailStep];
							setCell(grid, trailBlueRow, trailBlueCol, '=');
							setCell(grid, trailOrangeRow, trailOrangeCol, '-');
						}

						setCell(grid, blueRow, blueCol, 'B');
						setCell(grid, orangeRow, orangeCol, 'R');

						return serializeGrid(grid);
					}),
				),
				createArt(
					'missile-command',
					'missile command city defense',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const incomingLeftRow = step;
						const incomingRightRow = step;
						const incomingLeftCol = step;
						const incomingRightCol = 9 - step;

						drawText(grid, 9, 0, '^ ^ ^ ^ ^ ');
						drawText(grid, 8, 3, '[M]');

						setCell(grid, incomingLeftRow, incomingLeftCol, '!');
						setCell(grid, incomingRightRow, incomingRightCol, '!');

						if (step >= 2 && step <= 7) {
							setCell(grid, 8 - (step - 2), 4, '|');
						}

						if (step >= 5 && step <= 7) {
							setCell(grid, 4, 4, '*');
							setCell(grid, 4, 5, '*');
							setCell(grid, 5, 4, '*');
							setCell(grid, 5, 5, '*');
						}

						return serializeGrid(grid);
					}),
				),
				createArt(
					'asteroids',
					'asteroids drift and blast',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();

						drawText(grid, 9, 3, '/A\\');

						if (step <= 3) {
							setCell(grid, 1 + step, 8 - step, 'O');
							setCell(grid, 8 - step, 4, '|');
						} else if (step === 4) {
							setCell(grid, 4, 4, '*');
						} else if (step === 5) {
							setCell(grid, 3, 3, 'o');
							setCell(grid, 5, 5, 'o');
						} else if (step === 6) {
							setCell(grid, 2, 2, 'o');
							setCell(grid, 6, 6, 'o');
						} else if (step === 7) {
							setCell(grid, 1, 1, 'o');
						} else if (step === 8) {
							setCell(grid, 1, 9, 'O');
						} else {
							setCell(grid, 1, 8, 'O');
						}

						return serializeGrid(grid);
					}),
				),
				createArt(
					'galaga',
					'galaga dive and rejoin',
					Array.from({ length: FRAME_COUNT }, (_, step) => {
						const grid = buildGrid();
						const [enemyRow, enemyCol] = galagaDive[step];

						drawText(grid, 0, 1, 'W W W');
						drawText(grid, 1, 1, 'M   M');

						if (step >= 2 && step <= 6) {
							setCell(grid, 8 - step, 4, '|');
						}

						setCell(grid, enemyRow, enemyCol, 'V');
						drawText(grid, 9, 3, '/A\\');

						return serializeGrid(grid);
					}),
				),
			];

			if (!validateArcadeArtSet(arcadeArt)) {
				console.error('Invalid homepage arcade art configuration', {
					artCount: arcadeArt.length,
					expectedArtCount: 10,
				});
				return;
			}

			const bugBlock = document.querySelector('.ascii-bug-block');
			const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
			let currentTheme = theme;
			const cycleIndex = Number.parseInt(localStorage.getItem('home-accent-cycle-index') ?? '0', 10) || 0;
			const storedArtIndex = Number.parseInt(localStorage.getItem(artCycleKey) ?? '-1', 10);
			const artIndex = Number.isFinite(storedArtIndex)
				? (storedArtIndex + 1) % arcadeArt.length
				: 0;
			let footerStep = 0;
			let artFrameStep = 0;

			localStorage.setItem(artCycleKey, String(artIndex));

			const solidChars = new Set(['#', '=', '|', '[', ']', '<', '>', 'H']);
			const effectChars = new Set(['*', '@']);
			const pelletChars = new Set(['.']);
			const artCells = Array.from({ length: GRID_SIZE * GRID_SIZE }, () => {
				const cell = document.createElement('span');
				cell.className = 'ascii-cell ascii-cell--empty';
				cell.setAttribute('aria-hidden', 'true');
				return cell;
			});
			artEl.replaceChildren(...artCells);

			const setAccent = (nextTheme, index) => {
				const palette = accentPalettes[((index % accentPalettes.length) + accentPalettes.length) % accentPalettes.length];
				const accent = palette[nextTheme];

				[root, document.body].forEach((target) => {
					if (!target) {
						return;
					}

					target.style.setProperty('--home-accent', accent.hex);
					target.style.setProperty('--home-accent-glow', accent.glow);
					target.style.setProperty('--home-accent-dim', accent.dim);
				});

				return { ...accent, name: palette.name };
			};

			const syncThemeLabel = (themeValue) => {
				themeLabel.textContent = themeValue;
			};

			const applyAccent = (nextTheme = currentTheme) => {
				currentTheme = nextTheme;
				return setAccent(currentTheme, cycleIndex);
			};

			const accent = applyAccent(currentTheme);
			syncThemeLabel(currentTheme);
			statusText.textContent =
				statusMessages[Math.floor(Math.random() * statusMessages.length)];

			const bootLines = [
				`booting kartik.sh -- palette: ${accent.name}`,
				'loading /posts... done',
				`loading sprite: ${arcadeArt[artIndex].name}`,
				'syncing with the late shift...',
				'init complete. rendering...',
			];

			let bootIndex = 0;
			const playBoot = () => {
				if (bootIndex >= bootLines.length) {
					bootEl.classList.add('hidden');
					window.setTimeout(() => bootEl.remove(), 500);
					return;
				}

				bootLine.textContent = bootLines[bootIndex];
				bootIndex += 1;
				window.setTimeout(playBoot, bootIndex === 1 ? 420 : 180);
			};

			const getAsciiCellClass = (char) => {
				if (char === EMPTY_CELL) {
					return 'ascii-cell ascii-cell--empty';
				}

				if (effectChars.has(char)) {
					return 'ascii-cell ascii-cell--fx';
				}

				if (pelletChars.has(char)) {
					return 'ascii-cell ascii-cell--pellet';
				}

				if (solidChars.has(char)) {
					return 'ascii-cell ascii-cell--solid';
				}

				return 'ascii-cell ascii-cell--sprite';
			};
			const renderArcadeArt = (frames, title, frameIndex) => {
				const frame = frames[frameIndex % frames.length];
				frame.forEach((line, row) => {
					[...line].forEach((char, col) => {
						const cell = artCells[row * GRID_SIZE + col];

						cell.textContent = char === EMPTY_CELL ? '\u00A0' : char;
						cell.className = getAsciiCellClass(char);
					});
				});
				artEl.setAttribute('aria-label', title);

				if (bugBlock instanceof HTMLElement) {
					bugBlock.title = title;
				}
			};

			const selectedArt = arcadeArt[artIndex];
			const animationFrames = selectedArt.frames;
			renderArcadeArt(animationFrames, selectedArt.title, artFrameStep);

			if (animationFrames.length > 1) {
				window.setInterval(() => {
					artFrameStep = (artFrameStep + 1) % animationFrames.length;
					renderArcadeArt(animationFrames, selectedArt.title, artFrameStep);
				}, selectedArt.speed);
			}

			window.setInterval(() => {
				footerBug.textContent = footerFrames[footerStep % footerFrames.length];
				footerStep += 1;
			}, 480);

			themeToggle.addEventListener('click', () => {
				const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
				root.dataset.theme = nextTheme;
				root.style.colorScheme = nextTheme;
				localStorage.setItem(storageKey, nextTheme);
				syncThemeLabel(nextTheme);
			});

			const observer = new MutationObserver(() => {
				const nextTheme = root.dataset.theme === 'light' ? 'light' : 'dark';

				if (nextTheme === currentTheme) {
					return;
				}

				const storedTheme = localStorage.getItem(storageKey);
				currentTheme = storedTheme === 'light' ? 'light' : 'dark';
				syncThemeLabel(currentTheme);
				applyAccent(currentTheme);
			});

			observer.observe(root, { attributes: true, attributeFilter: ['data-theme'] });
			window.setTimeout(playBoot, 80);
		})();
	</script>

