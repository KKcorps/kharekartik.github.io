			const wrap = (value) => ((value % GRID_SIZE) + GRID_SIZE) % GRID_SIZE;
			const setCell = (grid, row, col, char) => {
				if (row < 0 || row >= GRID_SIZE || col < 0 || col >= GRID_SIZE) {
					return;
				}

				grid[row][col] = char;
			};
			const setWrappedCell = (grid, row, col, char) => {
