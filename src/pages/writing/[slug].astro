---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getPosts } from '../../lib/content';

export async function getStaticPaths() {
	const posts = await getCollection('posts', ({ data }) => !data.draft);

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getPosts();
const currentIndex = posts.findIndex((entry) => entry.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 && currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined;
const readTimeMinutes = Math.max(
	1,
	Math.round((post.body ?? '').split(/\s+/).filter(Boolean).length / 220),
);
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
const yyyyMmDd = post.data.publishedOn.toISOString().slice(0, 10);
---

<SiteLayout title={post.data.title} description={post.data.summary} hideChrome bodyClass="article-page">
	<script>
		import mermaid from 'mermaid';

		const getThemeVariables = () => {
			const styles = getComputedStyle(document.documentElement);
			const accent = styles.getPropertyValue('--accent').trim() || '#39ff14';
			const articleBg = styles.getPropertyValue('--article-pre-bg').trim() || '#111111';
			const articleText = styles.getPropertyValue('--article-text').trim() || '#f0f0f0';
			const articleProse = styles.getPropertyValue('--article-prose').trim() || '#c8c8c8';
			const articleRule = styles.getPropertyValue('--article-rule').trim() || '#222222';
			const articleHeading = styles.getPropertyValue('--article-heading').trim() || '#e0e0e0';
			const isLight = document.documentElement.dataset.theme === 'light';

			return {
				theme: isLight ? 'base' : 'base',
				themeVariables: {
					background: articleBg,
					primaryColor: isLight ? '#edf2e9' : '#0d120d',
					primaryTextColor: articleText,
					primaryBorderColor: accent,
					lineColor: accent,
					secondaryColor: isLight ? '#f7f8f5' : '#111111',
					secondaryTextColor: articleText,
					secondaryBorderColor: articleRule,
					tertiaryColor: isLight ? '#f1f4ef' : '#161616',
					tertiaryTextColor: articleProse,
					tertiaryBorderColor: articleRule,
					mainBkg: isLight ? '#edf2e9' : '#0d120d',
					secondBkg: isLight ? '#f7f8f5' : '#111111',
					tertiaryBkg: isLight ? '#f1f4ef' : '#161616',
					nodeBkg: isLight ? '#edf2e9' : '#0d120d',
					nodeBorder: accent,
					clusterBkg: isLight ? '#f1f4ef' : '#111111',
					clusterBorder: articleRule,
					defaultLinkColor: accent,
					titleColor: articleHeading,
					textColor: articleText,
					fontFamily: 'IBM Plex Mono, monospace',
				},
			};
		};

		const upgradeMermaidBlocks = () => {
			document.querySelectorAll('pre[data-language="mermaid"] > code').forEach((codeBlock, index) => {
				const pre = codeBlock.parentElement;
				if (!(pre instanceof HTMLElement) || pre.dataset.mermaidUpgraded === 'true') {
					return;
				}

				const wrapper = document.createElement('figure');
				wrapper.className = 'mermaid-figure';
				wrapper.dataset.mermaidSource = codeBlock.textContent ?? '';
				wrapper.dataset.mermaidIndex = String(index);

				const graph = document.createElement('div');
				graph.className = 'mermaid';
				graph.id = `mermaid-diagram-${index}`;
				graph.textContent = wrapper.dataset.mermaidSource;

				wrapper.append(graph);
				pre.replaceWith(wrapper);
			});
		};

		const syncDiagramScale = (figure) => {
			if (!(figure instanceof HTMLElement)) {
				return;
			}

			const viewport = figure.querySelector('.mermaid-viewport');
			if (!(viewport instanceof HTMLElement)) {
				return;
			}

			const currentScale = Number.parseFloat(figure.dataset.scale ?? '1');
			const nextScale = Number.isFinite(currentScale)
				? Math.min(Math.max(currentScale, 0.4), 2.5)
				: 1;

			figure.dataset.scale = String(nextScale);
			viewport.style.setProperty('--mermaid-scale', String(nextScale));
		};

		const attachDiagramControls = (figure) => {
			if (!(figure instanceof HTMLElement) || figure.dataset.mermaidReady === 'true') {
				return;
			}

			const svg = figure.querySelector('svg');
			if (!(svg instanceof SVGElement)) {
				return;
			}

			const controls = document.createElement('div');
			controls.className = 'mermaid-controls';
			controls.innerHTML = `
				<button type="button" data-mermaid-zoom="out" aria-label="Zoom out">-</button>
				<button type="button" data-mermaid-zoom="reset" aria-label="Reset zoom">Reset</button>
				<button type="button" data-mermaid-zoom="in" aria-label="Zoom in">+</button>
			`;

			const viewport = document.createElement('div');
			viewport.className = 'mermaid-viewport';

			const canvas = document.createElement('div');
			canvas.className = 'mermaid-canvas';
			canvas.append(svg);
			viewport.append(canvas);

			figure.append(controls, viewport);
			figure.dataset.mermaidReady = 'true';
			syncDiagramScale(figure);

			controls.addEventListener('click', (event) => {
				const target = event.target;
				if (!(target instanceof HTMLButtonElement)) {
					return;
				}

				const action = target.dataset.mermaidZoom;
				const scale = Number.parseFloat(figure.dataset.scale ?? '1') || 1;
				const nextScale =
					action === 'in'
						? Math.min(scale + 0.15, 2.5)
						: action === 'out'
							? Math.max(scale - 0.15, 0.4)
							: 1;

				figure.dataset.scale = String(nextScale);
				syncDiagramScale(figure);
			});
		};

		const renderMermaidBlocks = async () => {
			upgradeMermaidBlocks();

			const figures = Array.from(document.querySelectorAll('.mermaid-figure'));
			if (figures.length === 0) {
				return;
			}

			mermaid.initialize({
				startOnLoad: false,
				securityLevel: 'loose',
				...getThemeVariables(),
			});

			for (const [index, figure] of figures.entries()) {
				if (!(figure instanceof HTMLElement)) {
					continue;
				}

				const source = figure.dataset.mermaidSource ?? '';
				const graph = document.createElement('div');
				graph.className = 'mermaid';
				graph.id = `mermaid-diagram-${index}`;
				graph.textContent = source;
				figure.dataset.mermaidReady = 'false';
				figure.replaceChildren(graph);
			}

			await mermaid.run({
				querySelector: '.mermaid',
			});

			document.querySelectorAll('.mermaid-figure').forEach((figure) => {
				attachDiagramControls(figure);
			});
		};

		const bootMermaid = () => {
			void renderMermaidBlocks();

			const observer = new MutationObserver((mutations) => {
				if (
					mutations.some(
						(mutation) =>
							mutation.type === 'attributes' &&
							mutation.attributeName === 'data-theme',
					)
				) {
					void renderMermaidBlocks();
				}
			});

			observer.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ['data-theme'],
			});

			window.addEventListener('resize', () => {
				document.querySelectorAll('.mermaid-figure').forEach((figure) => {
					syncDiagramScale(figure);
				});
			});
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', bootMermaid, { once: true });
		} else {
			bootMermaid();
		}
	</script>

	<script is:inline>
		(() => {
			const accentCycleKey = 'home-accent-cycle-index';
			const accentPaletteKey = 'home-accent-palette';
			const root = document.documentElement;
			const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
			const parseHexToRgb = (hex) => {
				const normalized = hex.replace('#', '').trim();
				if (!/^[0-9a-fA-F]{6}$/.test(normalized)) {
					return null;
				}

				const red = Number.parseInt(normalized.slice(0, 2), 16);
				const green = Number.parseInt(normalized.slice(2, 4), 16);
				const blue = Number.parseInt(normalized.slice(4, 6), 16);

				return `${red} ${green} ${blue}`;
			};
			const accentPalettes = [
				{ dark: { hex: '#00e5ff', glow: 'rgba(0,229,255,0.25)', dim: 'rgba(0,229,255,0.12)' }, light: { hex: '#0b82a8', glow: 'rgba(11,130,168,0.2)', dim: 'rgba(11,130,168,0.14)' } },
				{ dark: { hex: '#00ffc8', glow: 'rgba(0,255,200,0.24)', dim: 'rgba(0,255,200,0.1)' }, light: { hex: '#0c8a6a', glow: 'rgba(12,138,106,0.18)', dim: 'rgba(12,138,106,0.12)' } },
				{ dark: { hex: '#ff7a1a', glow: 'rgba(255,122,26,0.24)', dim: 'rgba(255,122,26,0.1)' }, light: { hex: '#cc5a2f', glow: 'rgba(204,90,47,0.18)', dim: 'rgba(204,90,47,0.12)' } },
				{ dark: { hex: '#9d7dff', glow: 'rgba(157,125,255,0.24)', dim: 'rgba(157,125,255,0.1)' }, light: { hex: '#8e4ec6', glow: 'rgba(142,78,198,0.2)', dim: 'rgba(142,78,198,0.14)' } },
				{ dark: { hex: '#c5ff47', glow: 'rgba(197,255,71,0.22)', dim: 'rgba(197,255,71,0.1)' }, light: { hex: '#8b6f16', glow: 'rgba(139,111,22,0.18)', dim: 'rgba(139,111,22,0.12)' } },
				{ dark: { hex: '#ff5a6f', glow: 'rgba(255,90,111,0.24)', dim: 'rgba(255,90,111,0.1)' }, light: { hex: '#bf3f4f', glow: 'rgba(191,63,79,0.2)', dim: 'rgba(191,63,79,0.12)' } },
				{ dark: { hex: '#7be7ff', glow: 'rgba(123,231,255,0.24)', dim: 'rgba(123,231,255,0.1)' }, light: { hex: '#3c7f96', glow: 'rgba(60,127,150,0.2)', dim: 'rgba(60,127,150,0.12)' } },
				{ dark: { hex: '#9cff57', glow: 'rgba(156,255,87,0.22)', dim: 'rgba(156,255,87,0.1)' }, light: { hex: '#658d20', glow: 'rgba(101,141,32,0.18)', dim: 'rgba(101,141,32,0.12)' } },
				{ dark: { hex: '#ffb347', glow: 'rgba(255,179,71,0.22)', dim: 'rgba(255,179,71,0.1)' }, light: { hex: '#a56d16', glow: 'rgba(165,109,22,0.18)', dim: 'rgba(165,109,22,0.12)' } },
				{ dark: { hex: '#d17cff', glow: 'rgba(209,124,255,0.24)', dim: 'rgba(209,124,255,0.1)' }, light: { hex: '#9d56bb', glow: 'rgba(157,86,187,0.2)', dim: 'rgba(157,86,187,0.12)' } },
				{ dark: { hex: '#ff8b7b', glow: 'rgba(255,139,123,0.24)', dim: 'rgba(255,139,123,0.1)' }, light: { hex: '#c66556', glow: 'rgba(198,101,86,0.2)', dim: 'rgba(198,101,86,0.12)' } },
				{ dark: { hex: '#52ffc1', glow: 'rgba(82,255,193,0.24)', dim: 'rgba(82,255,193,0.1)' }, light: { hex: '#1f8b6c', glow: 'rgba(31,139,108,0.2)', dim: 'rgba(31,139,108,0.12)' } },
				{ dark: { hex: '#4fa3ff', glow: 'rgba(79,163,255,0.24)', dim: 'rgba(79,163,255,0.1)' }, light: { hex: '#2b69b3', glow: 'rgba(43,105,179,0.2)', dim: 'rgba(43,105,179,0.12)' } },
				{ dark: { hex: '#ff6bb5', glow: 'rgba(255,107,181,0.24)', dim: 'rgba(255,107,181,0.1)' }, light: { hex: '#b64b80', glow: 'rgba(182,75,128,0.2)', dim: 'rgba(182,75,128,0.12)' } },
				{ dark: { hex: '#ffd84d', glow: 'rgba(255,216,77,0.22)', dim: 'rgba(255,216,77,0.1)' }, light: { hex: '#9f7e10', glow: 'rgba(159,126,16,0.18)', dim: 'rgba(159,126,16,0.12)' } },
				{ dark: { hex: '#30e0a1', glow: 'rgba(48,224,161,0.24)', dim: 'rgba(48,224,161,0.1)' }, light: { hex: '#24775c', glow: 'rgba(36,119,92,0.2)', dim: 'rgba(36,119,92,0.12)' } },
				{ dark: { hex: '#7f8cff', glow: 'rgba(127,140,255,0.24)', dim: 'rgba(127,140,255,0.1)' }, light: { hex: '#5a63b8', glow: 'rgba(90,99,184,0.2)', dim: 'rgba(90,99,184,0.12)' } },
				{ dark: { hex: '#ff9e6d', glow: 'rgba(255,158,109,0.24)', dim: 'rgba(255,158,109,0.1)' }, light: { hex: '#bb7145', glow: 'rgba(187,113,69,0.2)', dim: 'rgba(187,113,69,0.12)' } },
				{ dark: { hex: '#64ffd9', glow: 'rgba(100,255,217,0.24)', dim: 'rgba(100,255,217,0.1)' }, light: { hex: '#298a76', glow: 'rgba(41,138,118,0.2)', dim: 'rgba(41,138,118,0.12)' } },
				{ dark: { hex: '#b89cff', glow: 'rgba(184,156,255,0.24)', dim: 'rgba(184,156,255,0.1)' }, light: { hex: '#7e66bb', glow: 'rgba(126,102,187,0.2)', dim: 'rgba(126,102,187,0.12)' } },
				{ dark: { hex: '#ff4d57', glow: 'rgba(255,77,87,0.24)', dim: 'rgba(255,77,87,0.1)' }, light: { hex: '#a8353c', glow: 'rgba(168,53,60,0.2)', dim: 'rgba(168,53,60,0.12)' } },
			];

			const storedCycleIndex = Number.parseInt(localStorage.getItem(accentCycleKey) ?? '-1', 10);
			const cycleIndex = Number.isFinite(storedCycleIndex)
				? (storedCycleIndex + 1) % accentPalettes.length
				: 0;
			const palette = accentPalettes[cycleIndex];
			const accent = palette[theme];
			const accentRgb = parseHexToRgb(accent.hex);

			localStorage.setItem(accentCycleKey, String(cycleIndex));
			localStorage.setItem(accentPaletteKey, JSON.stringify(palette));

			root.style.setProperty('--accent', accent.hex);
			root.style.setProperty('--accent-dim', accent.dim);
			if (accentRgb) {
				root.style.setProperty('--accent-rgb', accentRgb);
			}
		})();
	</script>
	<div class="shell">
		<nav class="article-nav">
			<a href={withBase('/')} class="logo">kartik khare<span class="cursor-block"></span></a>
			<div class="article-nav__actions">
				<a href={withBase('/about/')} class="nav-link">ABOUT</a>
				<ThemeToggle />
			</div>
		</nav>

		<div class="article-gap" aria-hidden="true"></div>
		<hr />

		<div class="breadcrumb">
			<span class="user">kartik</span>@site:<a href={withBase('/writing/')}>~/posts</a>/<span class="active">{post.id}</span> $
		</div>

		<header class="article-header">
			<h1 class="article-title">{post.data.title}</h1>
			<div class="article-meta">
				<span>{yyyyMmDd}</span>
				<span class="sep">/</span>
				<span>{readTimeMinutes} min read</span>
				{post.data.tags.map((tag) => (
					<>
						<span class="sep">/</span>
						<span class="tag">{tag}</span>
					</>
				))}
			</div>
		</header>

		<hr />

		<article class="article-body">
			<div class="prose" data-reading-article>
				<Content />
			</div>
		</article>

		<div class="post-nav">
			{
				olderPost ? (
					<a href={withBase(`/writing/${olderPost.id}/`)}>
						<div>
							<span class="nav-label">← OLDER POST</span>
							{olderPost.data.title}
						</div>
					</a>
				) : (
					<span></span>
				)
			}
			{
				newerPost ? (
					<a href={withBase(`/writing/${newerPost.id}/`)}>
						<div class="post-nav__right">
							<span class="nav-label">NEWER POST →</span>
							{newerPost.data.title}
						</div>
					</a>
				) : (
					<span></span>
				)
			}
		</div>

		<footer class="article-footer">
			<nav class="footer-links">
				<a href="https://medium.com/@kharekartik" target="_blank" rel="noreferrer">MEDIUM</a>
				<a href="https://github.com/kharekartik" target="_blank" rel="noreferrer">GITHUB</a>
				<a href="mailto:kharekartik@gmail.com">EMAIL</a>
			</nav>
		</footer>
	</div>
</SiteLayout>
