---
import type { CollectionEntry } from 'astro:content';
import { formatMonthYear } from '../lib/content';

interface Props {
	project: CollectionEntry<'projects'>;
	compact?: boolean;
}

const { project, compact = false } = Astro.props;
const stackPreview = project.data.stack.slice(0, 3).join(' / ') || 'project';
const statusClass = `project-preview__status project-preview__status--${project.data.status.toLowerCase()}`;
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
---

<article class:list={['project-preview', compact && 'project-preview--compact']}>
	<div class="project-preview__meta">
		<span class={statusClass}>{project.data.status}</span>
		<span>{formatMonthYear(project.data.startedOn)}</span>
	</div>

	<h3>
		<a href={withBase(`/projects/${project.id}/`)}>{project.data.title}</a>
	</h3>

	{!compact && <p class="project-preview__summary">{project.data.summary}</p>}
	<p class="project-preview__stack">{stackPreview}</p>
</article>
