---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	hideChrome?: boolean;
	bodyClass?: string;
}

const siteName = 'Kartik Khare';
const defaultDescription =
	'Writeups about side projects, ongoing experiments, and the systems details worth keeping.';
const { title, description = defaultDescription, hideChrome = false, bodyClass = '' } = Astro.props;
const pageTitle = title ? `${title} | ${siteName}` : `${siteName} | Build notes and project writeups`;
const pathname = Astro.url.pathname;
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;

const navItems = [
	{ href: '/', label: 'Home', match: pathname === '/' },
	{ href: '/about/', label: 'About', match: pathname.startsWith('/about/') },
	{ href: '/writing/', label: 'Writing', match: pathname.startsWith('/writing/') },
	{ href: '/projects/', label: 'Projects', match: pathname.startsWith('/projects/') },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" sizes="any" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<title>{pageTitle}</title>
		<script is:inline>
			(() => {
				const storageKey = 'theme-preference';
				const accentPaletteKey = 'home-accent-palette';
				const root = document.documentElement;
				const storedTheme = localStorage.getItem(storageKey);
				const preferredTheme = storedTheme || 'dark';
				const parseHexToRgb = (hex) => {
					const normalized = hex.replace('#', '').trim();
					if (!/^[0-9a-fA-F]{6}$/.test(normalized)) {
						return null;
					}

					const red = Number.parseInt(normalized.slice(0, 2), 16);
					const green = Number.parseInt(normalized.slice(2, 4), 16);
					const blue = Number.parseInt(normalized.slice(4, 6), 16);

					return `${red} ${green} ${blue}`;
				};

				root.dataset.theme = preferredTheme;
				root.style.colorScheme = preferredTheme;

				const storedPalette = localStorage.getItem(accentPaletteKey);
				if (!storedPalette) {
					return;
				}

				try {
					const palette = JSON.parse(storedPalette);
					const accent = preferredTheme === 'light' ? palette?.light : palette?.dark;
					if (!accent?.hex || !accent?.dim) {
						return;
					}

					root.style.setProperty('--accent', accent.hex);
					root.style.setProperty('--accent-dim', accent.dim);
					const accentRgb = parseHexToRgb(accent.hex);
					if (accentRgb) {
						root.style.setProperty('--accent-rgb', accentRgb);
					}
				} catch {
					// ignore malformed localStorage values
				}
			})();
		</script>
	</head>
	<body class={bodyClass}>
		{
			!hideChrome && (
				<>
					<div class="site-backdrop" aria-hidden="true">
						<div class="site-backdrop__glow"></div>
						<div class="site-backdrop__scanline"></div>
					</div>

					<header class="site-header">
						<a class="site-header__brand" href={import.meta.env.BASE_URL}>
							<span class="site-header__brand-title">{siteName}</span>
							<span class="site-header__brand-note">build notes / project logs</span>
						</a>

						<nav class="site-nav" aria-label="Primary">
							{
								navItems.map((item) => (
									<a class={item.match ? 'is-active' : undefined} href={withBase(item.href)}>
										{item.label}
									</a>
								))
							}
						</nav>

						<ThemeToggle />
					</header>
				</>
			)
		}

		<main class="site-main">
			<slot />
		</main>

		{
			!hideChrome && (
				<footer class="site-footer">
					<p class="site-footer__brand">KK // BUILD NOTES</p>
					<div class="site-footer__status">
						<span class="site-footer__dot" aria-hidden="true"></span>
						<span>ACTIVE // {year}</span>
					</div>
				</footer>
			)
		}
	</body>
</html>
